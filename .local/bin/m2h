#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["markdown"]
# ///
"""Convert markdown to HTML and copy to the macOS clipboard as rich text."""

import argparse
import subprocess
import sys

import markdown


def copy_html_to_clipboard(html: str) -> None:
    # macOS pasteboard accepts HTML via AppleScript's «data HTML…» literal.
    # Hex-encode so we don't have to escape quotes/newlines inside the AppleScript.
    hex_data = html.encode("utf-8").hex()
    subprocess.run(
        ["osascript", "-e", f"set the clipboard to «data HTML{hex_data}»"],
        check=True,
    )


def main() -> None:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("file", nargs="?", help="markdown file (stdin if omitted)")
    args = parser.parse_args()

    src = open(args.file).read() if args.file else sys.stdin.read()
    html = markdown.markdown(src, extensions=["extra", "sane_lists", "nl2br"])
    copy_html_to_clipboard(html)
    print("Copied HTML to clipboard.", file=sys.stderr)


if __name__ == "__main__":
    main()
